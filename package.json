{
  "name": "prismstudio",
  "version": "0.1.0",
  "description": "多模态生成控制台：图像 / 视频 / 音频一键生成，兼容国内外主流模型，内嵌 WebUI 配置与试用台。",
  "license": "MIT",
  "author": "Jacky Huang",
  "type": "module",
  "homepage": "https://github.com/RunhuaHuang/prismstudio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RunhuaHuang/prismstudio.git"
  },
  "bugs": {
    "url": "https://github.com/RunhuaHuang/prismstudio/issues"
  },
  "bin": {
    "prismstudio": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:webui": "tsx src/index.ts --webui",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "image-generation",
    "video-generation",
    "tts",
    "audio-generation",
    "text-to-speech",
    "music-generation",
    "voice-clone",
    "openai",
    "gemini",
    "nano-banana",
    "veo",
    "seedream",
    "seedance",
    "cogvideo",
    "cogview",
    "cosyvoice",
    "dashscope",
    "qwen",
    "minimax",
    "kling",
    "midjourney",
    "claude-desktop",
    "cursor",
    "cline",
    "webui",
    "ai"
  ]
}
